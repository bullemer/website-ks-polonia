<IfModule mod_rewrite.c>
  RewriteEngine On

  # ============================================
  # Force WWW (and HTTPS)
  # ============================================
  RewriteCond %{HTTP_HOST} ^ks-polonia\.de$ [NC]
  RewriteRule ^(.*)$ https://www.ks-polonia.de/$1 [L,R=301]

  # ============================================
  # 301 Redirects: Old WordPress URLs → New Astro URLs
  # ============================================

  # Basketball pages
  RewriteRule ^basketball-fuer-kinder-in-hamburg-uhlenhorst/?$ /seiten/basketball-jugend-u10 [R=301,L]
  RewriteRule ^basketball-hamburg-herren-ue35/?$ /seiten/basketball-herren-ue35 [R=301,L]

  # News articles (old WordPress /YYYY/MM/DD/slug/ format → new /news/slug)
  RewriteRule ^2023/07/06/trauer-um-manfred-itzen/?$ /news/trauer-um-manfred-itzen [R=301,L]
  RewriteRule ^2023/07/02/polonia-stellt-den-ehrenamtler-des-monats/?$ /news/polonia-stellt-den-ehrenamtler-des-monats [R=301,L]
  RewriteRule ^2023/11/21/trainerwechsel-1-herren/?$ /news/trainerwechsel-1-herren [R=301,L]
  RewriteRule ^2024/11/16/ks-polonia-in-der-ard-mediathek-ein-besonderer-film-ueber-unsere-d-jugend-zur-berlinale-2024-in-der-ard/?$ /news/ks-polonia-in-der-ard-mediathek-ein-besonderer-film-ueber-unsere-d-jugend-zur-berlinale-2024-in-der-ard [R=301,L]
  RewriteRule ^2024/12/06/dfb-ehrenamtspreis-2025-fuer-polonia-praesidenten-manfred-wolny/?$ /news/dfb-ehrenamtspreis-2025-fuer-polonia-praesidenten-manfred-wolny [R=301,L]
  RewriteRule ^2025/01/10/der-ks-polonia-geht-als-dfb-goldklub-ins-neue-jahr/?$ /news/der-ks-polonia-geht-als-dfb-goldklub-ins-neue-jahr [R=301,L]
  RewriteRule ^2025/04/28/ks-polonia-triumphiert-unter-flutlicht-40-sieg-gegen-hafencity-fc-und-aufstieg-in-die-kreisliga/?$ /news/ks-polonia-triumphiert-unter-flutlicht-40-sieg-gegen-hafencity-fc-und-aufstieg-in-die-kreisliga [R=301,L]
  RewriteRule ^2025/08/06/david-gegen-goliath-in-der-ersten-pokalrunde/?$ /news/david-gegen-goliath-in-der-ersten-pokalrunde [R=301,L]

  # Old page slugs (WordPress flat structure → new /seiten/ prefix)
  RewriteRule ^geschichte/?$ /seiten/geschichte [R=301,L]
  RewriteRule ^sportplatz/?$ /seiten/sportplatz [R=301,L]
  RewriteRule ^veranstaltungen/?$ /seiten/veranstaltungen [R=301,L]
  RewriteRule ^vorstand/?$ /seiten/vorstand [R=301,L]
  RewriteRule ^aktuelles/?$ /seiten/aktuelles [R=301,L]
  RewriteRule ^1-herren/?$ /seiten/1-herren [R=301,L]
  RewriteRule ^b-jugend/?$ /seiten/b-jugend [R=301,L]
  RewriteRule ^ansprechpartner-erwachsense/?$ /seiten/vorstand [R=301,L]
  RewriteRule ^f-jugend-2016-2017/?$ /seiten/aktuelles [R=301,L]
  
  # New additions from GSC analysis
  RewriteRule ^impressum/?$ /seiten/impressum-2 [R=301,L]
  RewriteRule ^seiten/impressum/?$ /seiten/impressum-2 [R=301,L]
  RewriteRule ^seiten/galerie/?$ /galerie [R=301,L]
  RewriteRule ^seiten/kontaktformular/?$ /kontakt [R=301,L]
  RewriteRule ^kontaktformular/?$ /kontakt [R=301,L]
  RewriteRule ^seiten/home/?$ / [R=301,L]
  RewriteRule ^home/?$ / [R=301,L]
  RewriteRule ^probetraining/?$ /seiten/probetraining [R=301,L]
  RewriteRule ^spendenkonto/?$ /seiten/spendenkonto [R=301,L]
  RewriteRule ^sponsorwerden/?$ /seiten/sponsorwerden [R=301,L]
  RewriteRule ^trainingsformen-g-f-und-e-jugend/?$ /seiten/trainingsformen-g-f-und-e-jugend [R=301,L]
  RewriteRule ^datenschutz/?$ /seiten/datenschutz [R=301,L]
  RewriteRule ^satzung-2/?$ /seiten/satzung [R=301,L]
  RewriteRule ^trainingszeiten-jugend/?$ /seiten/trainingszeiten-jugend [R=301,L]
  RewriteRule ^c-jugend/?$ /seiten/c-jugend [R=301,L]
  RewriteRule ^ue50-1-mannschaft/?$ /seiten/ue50-1-mannschaft [R=301,L]
  RewriteRule ^erste-herren/?$ /seiten/erste-herren [R=301,L]
  RewriteRule ^e-jugend/?$ /seiten/e-jugend [R=301,L]
  RewriteRule ^ue40-1-mannschaft/?$ /seiten/ue40-1-mannschaft [R=301,L]
  RewriteRule ^d2-jugend/?$ /seiten/d2-jugend [R=301,L]
  RewriteRule ^mannschaften-jugend/?$ /seiten/mannschaften-jugend [R=301,L]
  RewriteRule ^d-jugend-1/?$ /seiten/d-jugend-1 [R=301,L]
  RewriteRule ^jugendkonzept/?$ /seiten/jugendkonzept [R=301,L]

  # Football Team URL Cleanup
  RewriteRule ^football/herren---polonia-1-/?$ /football/1-herren [R=301,L]
  RewriteRule ^football/herren---polonia-2-/?$ /football/2-herren [R=301,L]
  RewriteRule ^football/herren---polonia-3-/?$ /football/3-herren [R=301,L]
  RewriteRule ^football/herren---polonia-4-/?$ /football/4-herren [R=301,L]
  RewriteRule ^football/herren--40---polonia-1--40/?$ /football/ue40-herren [R=301,L]
  RewriteRule ^football/herren--50---polonia-1--50/?$ /football/ue50-herren [R=301,L]
  RewriteRule ^football/c-junioren---polonia-1-c--a1-/?$ /football/c-junioren-1 [R=301,L]
  RewriteRule ^football/c-junioren---polonia-2-c--j1-/?$ /football/c-junioren-2 [R=301,L]
  RewriteRule ^football/d-junioren---polonia-1-d--a1-/?$ /football/d-junioren [R=301,L]
  RewriteRule ^football/e-junioren---polonia-1-e--j1-/?$ /football/e-junioren [R=301,L]

  # Additional Missing Redirects
  RewriteRule ^downloads/?$ /downloads [R=301,L]
  RewriteRule ^mitglied-werden/?$ /mitgliedsantrag [R=301,L]
  RewriteRule ^ueber-uns/?$ /seiten/ueber-uns [R=301,L]

  # Redirect old WP uploads to homepage to avoid 404s for indexed PDFs
  RewriteRule ^wp-content/uploads/.*$ / [R=301,L]

  # Catch-all: old /YYYY/MM/DD/slug/ and /YYYY/MM/slug/ patterns → /news/slug
  RewriteRule ^[0-9]{4}/[0-9]{2}/[0-9]{2}/(.+?)/?$ /news/$1 [R=301,L]
  RewriteRule ^[0-9]{4}/[0-9]{2}/(.+?)/?$ /news/$1 [R=301,L]

</IfModule>
