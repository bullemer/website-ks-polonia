<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /api/
  
  # Ensure Authorization headers are passed to the FastCGI process
  CGIPassAuth On
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.*)$ api.fcgi/$1 [QSA,L]
</IfModule>
