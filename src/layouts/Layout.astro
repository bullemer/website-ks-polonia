<style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --color-primary: #DC143C;
        --color-primary-dark: #a5102e;
        --color-bg: #f8f9fb;
        --color-surface: #ffffff;
        --color-text: #1a1a2e;
        --color-text-muted: #6b7280;
        --color-border: #e5e7eb;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
        --radius: 8px;
    }

    body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }
    a { color: var(--color-primary); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--color-primary-dark); }
    img { max-width: 100%; height: auto; }

    /* ═══════════════════════════════════════
       HEADER
       ═══════════════════════════════════════ */
    .site-header {
        background: var(--color-surface);
        box-shadow: var(--shadow-sm);
        position: sticky; top: 0; z-index: 100;
    }

    .header-top {
        border-bottom: 1px solid var(--color-border);
    }
    .header-top-inner {
        display: flex;
        align-items: center;
        height: 72px;
        gap: 2rem;
    }

    .logo { flex-shrink: 0; line-height: 0; }
    .logo img { width: 52px; height: 52px; object-fit: contain; }

    .lang-selector { margin-left: auto; display: flex; align-items: center; min-height: 35px; }

    .header-tagline {
        background: var(--color-bg);
        border-bottom: 3px solid var(--color-primary);
        padding: 0.5rem 0;
    }
    .header-tagline p {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text);
    }

    /* ═══════════════════════════════════════
       NAV — Desktop
       ═══════════════════════════════════════ */
    .nav-list {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 0;
        margin: 0;
        padding: 0;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.6rem 0.85rem;
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--color-text);
        white-space: nowrap;
        border-radius: 4px;
        transition: background 0.15s, color 0.15s;
    }
    .nav-link:hover { background: rgba(220,20,60,0.06); color: var(--color-primary); }
    .caret { width: 10px; height: 6px; flex-shrink: 0; opacity: 0.5; }

    /* ── Dropdown ─────────────────────────── */
    .sub-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        list-style: none;
        margin: 0;
        padding: 0.4rem 0;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        min-width: 210px;
        box-shadow: var(--shadow-lg);
        z-index: 200;
    }
    .sub-right {
        left: 100%;
        top: 0;
    }

    .nav-item { position: relative; }
    .nav-item.has-sub:hover > .sub-menu { display: block; }
    .sub-menu li.has-sub:hover > .sub-menu { display: block; }

    .sub-menu a {
        display: block;
        padding: 0.45rem 1.1rem;
        font-size: 0.84rem;
        font-weight: 450;
        color: var(--color-text);
        transition: background 0.12s, color 0.12s;
    }
    .sub-menu a:hover {
        background: rgba(220,20,60,0.05);
        color: var(--color-primary);
    }

    /* ═══════════════════════════════════════
       MOBILE
       ═══════════════════════════════════════ */
    .menu-toggle {
        display: none;
        background: none; border: none; cursor: pointer;
        width: 28px; height: 22px; position: relative; flex-shrink: 0;
        margin-left: auto;
    }
    .menu-toggle span {
        display: block; width: 100%; height: 2px; background: var(--color-text);
        position: absolute; left: 0; transition: all 0.25s;
    }
    .menu-toggle span:nth-child(1) { top: 0; }
    .menu-toggle span:nth-child(2) { top: 10px; }
    .menu-toggle span:nth-child(3) { top: 20px; }
    .menu-toggle.active span:nth-child(1) { transform: rotate(45deg); top: 10px; }
    .menu-toggle.active span:nth-child(2) { opacity: 0; }
    .menu-toggle.active span:nth-child(3) { transform: rotate(-45deg); top: 10px; }

    @media (max-width: 900px) {
        .menu-toggle { display: block; }
        .main-nav {
            display: none;
            position: absolute;
            top: 72px; left: 0; right: 0;
            background: var(--color-surface);
            border-bottom: 2px solid var(--color-primary);
            box-shadow: var(--shadow-md);
            padding: 0.75rem 1.5rem;
        }
        .main-nav.open { display: block; }
        .nav-list { flex-direction: column; align-items: stretch; }
        .nav-item { position: static; }
        .sub-menu {
            position: static; box-shadow: none; border: none;
            padding: 0 0 0 1rem; min-width: 0;
        }
        .nav-item.has-sub > .sub-menu { display: none; }
        .nav-item.has-sub:hover > .sub-menu { display: block; }
        .sub-right { left: 0; top: 0; }
    }

    /* ═══════════════════════════════════════
       MAIN
       ═══════════════════════════════════════ */
    .site-main { flex: 1; padding: 2.5rem 0; }

    /* ═══════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════ */
    .site-footer { background: var(--color-text); color: #aaa; padding: 1.25rem 0; font-size: 0.8rem; margin-top: auto; }
    .footer-inner { display: flex; justify-content: space-between; align-items: center; }
    .footer-links { display: flex; gap: 1.25rem; }
    .footer-links a { color: #aaa; }
    .footer-links a:hover { color: #fff; }

    /* ═══════════════════════════════════════
       PROSE
       ═══════════════════════════════════════ */
    .prose { max-width: 720px; }
    .prose h1 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; letter-spacing: -0.02em; }
    .prose h2 { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; }
    .prose h3 { font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
    .prose p { margin-bottom: 1rem; }
    .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; }
    .prose li { margin-bottom: 0.4rem; }
    .prose blockquote { border-left: 3px solid var(--color-primary); padding: 0.75rem 1rem; margin: 1rem 0; background: rgba(220,20,60,0.03); color: var(--color-text-muted); }
    .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    .prose th, .prose td { padding: 0.6rem 0.8rem; border: 1px solid var(--color-border); text-align: left; }
    .prose th { background: var(--color-bg); font-weight: 600; }

    .footer-left { display: flex; flex-direction: column; gap: 0.2rem; }
    .system-status { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: #777; margin-top: 0.2rem; }
    .status-link { color: #777; text-decoration: none; transition: color 0.2s; }
    .status-link:hover { color: #fff; }
    .status-indicator { width: 8px; height: 8px; border-radius: 50%; background-color: #9ca3af; display: inline-block; }
    .status-indicator.ok { background-color: #10b981; box-shadow: 0 0 6px rgba(16, 185, 129, 0.4); }
    .status-indicator.warning { background-color: #f59e0b; box-shadow: 0 0 6px rgba(245, 158, 11, 0.4); }
    .status-indicator.error { background-color: #ef4444; box-shadow: 0 0 6px rgba(239, 68, 68, 0.4); }

    @media (max-width: 600px) {
        .footer-inner { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
</style>
