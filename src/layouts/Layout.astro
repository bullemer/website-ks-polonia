    <footer class="site-footer">
        <div class="container footer-inner">
            <div class="footer-left">
                <p>&copy; {new Date().getFullYear()} KS Polonia Hamburg e.V. 1988</p>
                <div class="system-status" id="system-status">
                    <span class="status-indicator"></span>
                    <a href="/status" class="status-link">
                        <span id="sys-version-web">Web: v1.0.0</span> | 
                        <span id="sys-version-api">API: prüfen...</span>
                    </a>
                </div>
            </div>
            <div class="footer-links">
                <a href="/seiten/impressum-2">Impressum</a>
                <a href="/seiten/datenschutz">Datenschutz</a>
                <a href="/status">System-Status</a>
            </div>
        </div>
    </footer>

    <script>
      const toggle = document.getElementById('menuToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        nav?.classList.toggle('open');
        toggle.classList.toggle('active');
      });

      // System Health Check for Footer
      async function checkSystemHealth() {
          const apiSpan = document.getElementById('sys-version-api');
          const indicator = document.querySelector('.status-indicator');
          if (!apiSpan) return;

          try {
              const res = await fetch('/api/health');
              if (res.ok) {
                  const data = await res.json();
                  apiSpan.textContent = `API: v${data.version || 'unknown'}`;
                  
                  if (data.api === 'ok' && data.database === 'ok') {
                      indicator.classList.add('ok');
                  } else {
                      indicator.classList.add('warning');
                  }
              } else {
                  apiSpan.textContent = 'API: offline';
                  indicator.classList.add('error');
              }
          } catch (e) {
              apiSpan.textContent = 'API: offline';
              indicator.classList.add('error');
          }
      }
      
      // Run once after load
      setTimeout(checkSystemHealth, 500);
    </script>
    
    <!-- Google Translate Script -->
