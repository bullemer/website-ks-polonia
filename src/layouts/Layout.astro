        "@context": "https://schema.org",
        "@type": "SportsOrganization",
        "name": "KS Polonia Hamburg e.V. 1988",
        "url": "https://www.ks-polonia.de",
        "logo": "https://www.ks-polonia.de/logo.png",
        "description": description,
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "Finkenau 36",
            "addressLocality": "Hamburg",
            "addressRegion": "Hamburg",
            "postalCode": "22081",
            "addressCountry": "DE"
        },
        "sport": ["Fußball", "Basketball", "Badminton"],
        "foundingDate": "1988"
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Analytics (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-66XQ9QNKSN"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-66XQ9QNKSN');
    </script>
</head>
