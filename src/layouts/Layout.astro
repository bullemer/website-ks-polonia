    <!-- Hreflang for multilingual audience -->
    <link rel="alternate" hreflang="de" href={canonicalUrl} />
    <link rel="alternate" hreflang="pl" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | KS Polonia Hamburg`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteBase}${image}`} />
