---
import { getCollection } from 'astro:content';

interface Props {
    title: string;
    description?: string;
    image?: string;
    canonicalUrl?: string;
    type?: string;
}

const siteBase = Astro.site?.origin || 'https://ks-polonia.de';
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '';
const defaultCanonical = `${siteBase}${pathname}`;

const { 
    title, 
    description = 'KS Polonia Hamburg e.V. 1988 – Polnischer Sportverein an der Finkenau mit Fußball, Basketball und Badminton',
    image = '/logo.png',
    canonicalUrl = defaultCanonical,
    type = 'website'
} = Astro.props;

// Fetch and filter the dynamically generated Fussball.de teams
const allTeams = await getCollection('teams');
const poloniaTeams = allTeams
    .filter(team => {
        const title = (team.data.title || team.data.teamName || '').toLowerCase();
        return title.includes('polonia');
    })
    .sort((a, b) => {
        const titleA = a.data.title || a.data.teamName || '';
        const titleB = b.data.title || b.data.teamName || '';
        return titleA.localeCompare(titleB);
    });

// To avoid excessive duplicates generated by Fussball.de's multiple naming conventions for the same team,
// we could do a unique filter based on the external URL:
const uniqueTeamsMap = new Map();
poloniaTeams.forEach(team => {
    if (team.data.externalUrl && !uniqueTeamsMap.has(team.data.externalUrl)) {
        uniqueTeamsMap.set(team.data.externalUrl, team);
    }
});
const uniquePoloniaTeams = Array.from(uniqueTeamsMap.values());

// Split unique teams into Herren and Jugend categories
const herrenTeams = uniquePoloniaTeams.filter(team => {
    const title = (team.data.title || team.data.teamName || '').toLowerCase();
    return title.includes('herren') || title.includes('ü40') || title.includes('ü50');
});

const jugendTeams = uniquePoloniaTeams.filter(team => {
    const title = (team.data.title || team.data.teamName || '').toLowerCase();
    return title.includes('junioren') || title.includes('jugend');
});
