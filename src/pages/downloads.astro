---
import Layout from '../layouts/Layout.astro';

const defaultDownloads = [
  {
    title: "Antrag auf Spielberechtigung",
    description: "Spielberechtigung",
    filename: "Antrag_Spielberechtigung_Polonia-Seiten-1-2.pdf"
  },
  {
    title: "Internationaler Vereinswechsel",
    description: "Senioren",
    filename: "Internationaler_Vereinswechsel-Polonia-ukrainisch.pdf"
  },
  {
    title: "Vereinswechsel Jugend",
    description: "Jugend",
    filename: "Internationaler_Vereinswechsel_-_Zusatz_Jugend.pdf"
  },
  {
    title: "Ehrenkodex",
    description: "Ehrenamt",
    filename: "Ehrenkodex-blanko.pdf"
  },
  {
    title: "Satzung KS Polonia",
    description: "Vereinsdokumente",
    filename: "Satzung-KS-Polonia-1988.pdf"
  },
  {
    title: "Leitfaden Mitgliedschaft",
    description: "Vereinsdokumente",
    filename: "Polonia-Merkblatt-mehrsprachig.pdf"
  },
  {
    title: "Verhaltensregeln",
    description: "Vereinsdokumente",
    filename: "Verhaltensregeln-Polonia.pdf"
  },
  {
    title: "Jugendkonzept",
    description: "Sportliches Konzept",
    filename: "Sportliches-Jugendkonzept-Polonia.pdf"
  },
  {
    title: "Zusatzerklärung für Nicht-Deutsche",
    description: "Spieler zwischen 10-18 Jahre",
    filename: "Zusatzerklaerung-fuer-Spieler-innen-zwischen-10-und-18-Jahren.pdf"
  }
];

---

<Layout 
  title="Downloads | KS Polonia Hamburg"
  description="Wichtige Formulare, Mitgliedsanträge, Satzung und Leitfäden des K.S. Polonia Hamburg e.V. zum Herunterladen."
>
  <div class="page-header">
    <div class="header-content">
      <h1>Downloads</h1>
      <p>Wichtige Formulare, Anträge und Leitfäden des K.S. Polonia Hamburg e.V.</p>
    </div>
  </div>

  <section class="downloads-section section-padding">
    <div class="container">
      <div class="downloads-grid">
        {defaultDownloads.map((doc) => (
          <a href={`/downloads/${doc.filename}`} class="download-card" download>
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="12" y1="18" x2="12" y2="12"></line>
                <polyline points="9 15 12 18 15 15"></polyline>
              </svg>
            </div>
            <div class="card-content">
              <h3>{doc.title}</h3>
              <p>{doc.description}</p>
            </div>
            <div class="card-action">
              <span>Herunterladen</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 4rem 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .header-content h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }

  .header-content p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .section-padding {
    padding: 2rem 0 6rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .download-card {
    background: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    position: relative;
    overflow: hidden;
  }

  .download-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    border-color: var(--color-primary, #DC143C);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: #fef2f2;
    color: var(--color-primary, #DC143C);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .card-icon svg {
    width: 24px;
    height: 24px;
  }

  .download-card:hover .card-icon {
    background: var(--color-primary, #DC143C);
    color: #ffffff;
  }

  .card-content {
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }

  .card-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }

  .card-content p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .card-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary, #DC143C);
    padding-top: 1rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
    transition: all 0.3s ease;
  }

  .card-action svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .download-card:hover .card-action {
    color: var(--color-primary-dark, #a5102e);
  }
  
  .download-card:hover .card-action svg {
    transform: translateX(4px);
  }
</style>
