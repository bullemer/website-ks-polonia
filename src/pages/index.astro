---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import WeatherWidget from '../components/WeatherWidget.astro';
import startpageData from '../content/startpage/index.json';

const allNews = await getCollection('news');
const allPages = await getCollection('pages');

// Sort news by date (newest first), fallback to title
const sortedNews = allNews.sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
});

const latestNews = sortedNews.slice(0, 6);
---

<Layout 
    title="Polnischer Sportverein Hamburg – Fußball, Basketball & Badminton in Uhlenhorst" 
    description="KS Polonia Hamburg e.V. 1988 – Polnischer Sportverein (polski klub sportowy) in Hamburg-Uhlenhorst. Fußball, Basketball und Badminton für Kinder, Jugendliche und Erwachsene. Probetraining jederzeit möglich!"
    type="website"
>
    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>{startpageData.heroTitle}</h1>
            <p class="hero-subtitle">{startpageData.heroSubtitle}</p>
        </div>
    </section>

    <!-- Latest News -->
    <section class="section">
        <div class="section-header">
            <h2>Aktuelle Nachrichten</h2>
            <a href="/news" class="view-all">Alle anzeigen →</a>
        </div>
        <div class="news-grid">
            {latestNews.map((post) => {
                const imgData = post.data.coverImage && typeof post.data.coverImage === 'object' && post.data.coverImage.src
                    ? post.data.coverImage : null;
                return (
                    <a href={`/news/${post.id}`} class="news-card">
                        <div class="news-card-image">
                            {imgData ? (
                                <Image src={imgData} alt={post.data.title || ''} width={400} height={267} />
                            ) : (
                                <div class="news-image-placeholder">
                                    <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <polyline points="21 15 16 10 5 21"/>
                                    </svg>
                                </div>
                            )}
                        </div>
                        <div class="news-card-body">
                            <h3>{post.data.title}</h3>
                            {post.data.date && (
                                <time class="news-date">
                                    {new Date(post.data.date).toLocaleDateString('de-DE', {
                                        day: '2-digit', month: 'long', year: 'numeric'
                                    })}
                                </time>
                            )}
                            {post.data.category && (
                                <span class="news-category">{post.data.category}</span>
                            )}
                        </div>
                    </a>
                );
            })}
        </div>
    </section>

    <!-- Gameday Dashboard (Matches + Weather) -->
    <section class="section">
        <div class="dashboard-grid">
            <!-- Next Matches Widget -->
            <div class="dashboard-card">
                <div class="section-header" style="margin-bottom: 1rem;">
                    <h2>Nächste Spiele</h2>
                    <a href="/spieltermine" class="view-all">Alle Termine →</a>
                </div>
                <div class="matches-widget-container" style="background: var(--color-surface); padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); height: 100%;">
                    <script is:inline type="text/javascript" src="https://www.fussball.de/widgets.js"></script>
                    <div 
                      class="fussballde_widget"
                      data-id="576e80b1-c9b0-4ea0-a1ca-b7bcf6a4b9b7"
                      data-type="club-matches"
                      style="width: 100%"
                    ></div>
                </div>
            </div>

            <!-- Weather & Status Widget -->
            <div class="dashboard-card">
                <div class="section-header" style="margin-bottom: 1rem;">
                    <h2>Wetter & Platzstatus</h2>
                </div>
                <WeatherWidget />
            </div>
        </div>
    </section>

    <!-- Unsere Sportarten – SEO: Internal Links to key sport pages -->
    <section class="section">
        <div class="section-header">
            <h2>Unsere Sportarten in Uhlenhorst &amp; Barmbek</h2>
        </div>
        <div class="sports-grid">
            <a href="/seiten/basketball-jugend-u10" class="sport-card sport-card--basketball">
                <span class="sport-icon">🏀</span>
                <h3>Basketball Kinder U10</h3>
                <p>Kinder-Basketball in Hamburg Uhlenhorst & Barmbek – Dienstags 17:00 Uhr. Probetraining jederzeit!</p>
                <span class="sport-cta">Mehr erfahren →</span>
            </a>
            <a href="/seiten/basketball-herren-ue35" class="sport-card sport-card--basketball">
                <span class="sport-icon">🏀</span>
                <h3>Basketball Herren Ü35</h3>
                <p>Freizeit-Basketball in Hamburg für Erwachsene – Dienstags 18:30 Uhr in Uhlenhorst/Barmbek.</p>
                <span class="sport-cta">Mehr erfahren →</span>
            </a>
            <a href="/seiten/aktuelles" class="sport-card sport-card--fussball">
                <span class="sport-icon">⚽</span>
                <h3>Fußball</h3>
                <p>Herren, Jugend &amp; Kinder – Spielbetrieb in der Kreisliga und im Pokal. Trainingsplatz an der Finkenau.</p>
                <span class="sport-cta">Mehr erfahren →</span>
            </a>
            <a href="/seiten/badminton" class="sport-card sport-card--badminton">
                <span class="sport-icon">🏸</span>
                <h3>Badminton</h3>
                <p>Badminton für Erwachsene in Hamburg – Regelmäßiges Training und Turniere.</p>
                <span class="sport-cta">Mehr erfahren →</span>
            </a>
        </div>
    </section>

    <!-- Pages Overview -->
    <section class="section">
        <div class="section-header">
            <h2>Seiten</h2>
            <a href="/seiten" class="view-all">Alle anzeigen →</a>
        </div>
        <div class="pages-grid">
            {allPages.slice(0, 8).map((page) => (
                <a href={`/seiten/${page.id}`} class="page-link">
                    {page.data.title}
                </a>
            ))}
        </div>
    </section>
</Layout>

<style>
    .hero {
        background: linear-gradient(135deg, #DC143C 0%, #8B0000 100%);
        color: white;
        padding: 4rem 2rem;
        border-radius: var(--radius);
        margin-bottom: 3rem;
        text-align: center;
        box-shadow: 0 8px 32px rgba(220,20,60,0.25);
    }
    .hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }
    .hero-subtitle {
        font-size: 1.15rem;
        opacity: 0.9;
        font-weight: 400;
    }

    .section {
        margin-bottom: 3rem;
    }
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid var(--color-border);
        padding-bottom: 0.75rem;
    }
    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
    }
    .view-all {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @media (min-width: 900px) {
        .dashboard-grid {
            grid-template-columns: 2fr 1fr;
        }
    }
    .dashboard-card {
        display: flex;
        flex-direction: column;
    }

    .news-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }
    .news-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }
    .news-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-4px);
        color: inherit;
    }
    .news-card-image {
        aspect-ratio: 3/2;
        overflow: hidden;
        background: #f1f5f9;
    }
    .news-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }
    .news-card:hover .news-card-image img {
        transform: scale(1.05);
    }
    .news-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        color: #94a3b8;
    }
    .news-card-body {
        padding: 1.25rem;
    }
    .news-card h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .news-date {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        display: block;
        margin-bottom: 0.25rem;
    }
    .news-category {
        font-size: 0.7rem;
        background: rgba(220,20,60,0.08);
        color: var(--color-primary);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .pages-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
    .page-link {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: 0.6rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-text);
        transition: background 0.15s, border-color 0.15s;
    }
    .page-link:hover {
        background: rgba(220,20,60,0.04);
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    /* Sports Section */
    .sports-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
    }
    .sport-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 1.5rem;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.25s, transform 0.2s, border-color 0.2s;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: relative;
        overflow: hidden;
    }
    .sport-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        border-radius: var(--radius) var(--radius) 0 0;
    }
    .sport-card--basketball::before { background: linear-gradient(90deg, #f97316, #ea580c); }
    .sport-card--fussball::before { background: linear-gradient(90deg, #22c55e, #16a34a); }
    .sport-card--badminton::before { background: linear-gradient(90deg, #3b82f6, #2563eb); }
    .sport-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
        border-color: var(--color-primary);
        color: inherit;
    }
    .sport-icon { font-size: 2rem; line-height: 1; }
    .sport-card h3 { font-size: 1.1rem; font-weight: 700; margin: 0; }
    .sport-card p { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; flex: 1; }
    .sport-cta { font-size: 0.85rem; font-weight: 600; color: var(--color-primary); margin-top: 0.5rem; }

    @media (max-width: 600px) {
        .hero { padding: 3rem 1.5rem; }
        .hero h1 { font-size: 2rem; }
        .news-grid { grid-template-columns: 1fr; }
        .sports-grid { grid-template-columns: 1fr; }
    }
</style>
