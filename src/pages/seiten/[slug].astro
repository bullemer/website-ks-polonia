---
import Layout from '../../layouts/Layout.astro';
import LocalSEO from '../../components/LocalSEO.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const pages = await getCollection('pages');
    return pages
        .filter(entry => entry.id !== 'aktuelles' && entry.id !== 'probetraining' && entry.id !== 'badminton' && entry.id !== 'sportplatz')
        .map(entry => ({
            params: { slug: entry.id },
            props: { entry },
        }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Basketball Local SEO config
const basketballSEO: Record<string, { teamName: string; teamDescription: string; trainingTime: string }> = {
    'basketball-jugend-u10': {
        teamName: 'KS Polonia Basketball U10',
        teamDescription: 'Hamburg Kinder Basketball U10 – Training für Mädchen und Jungen der Jahrgänge 2016/2017 in Hamburg-Uhlenhorst.',
        trainingTime: '17:00 – 18:30',
    },
    'basketball-herren-ue35': {
        teamName: 'KS Polonia Basketball Herren Ü35',
        teamDescription: 'Basketball Hamburg Ü35 Herren – Freizeitbasketball für Erwachsene in Hamburg-Uhlenhorst und Barmbek.',
        trainingTime: '18:30 – 20:00',
    },
};

const seoConfig = basketballSEO[entry.id];
const isBasketball = !!seoConfig;
---

<Layout 
    title={entry.data.title}
    description={entry.data.description || `Informationsseite über ${entry.data.title} beim polnischen Sportverein KS Polonia Hamburg.`}
>
    {isBasketball && seoConfig && (
        <LocalSEO
            sport="Basketball"
            teamName={seoConfig.teamName}
            teamDescription={seoConfig.teamDescription}
            trainingDay="Dienstag"
            trainingTime={seoConfig.trainingTime}
            trainingLocation="Schulsporthalle Uferstraße 10"
            trainingAddress="Uferstraße 10, 22081 Hamburg"
            pageUrl={`https://www.ks-polonia.de/seiten/${entry.id}`}
        />
    )}

    <article class="prose">
        <a href="/seiten" class="back-link">← Zurück zu Seiten</a>
        <h1>{entry.data.title}</h1>
        <div class="article-content">
            <Content />
        </div>
    </article>
</Layout>

<style>
    .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-text-muted);
    }
    .back-link:hover { color: var(--color-primary); }
    .article-content {
        line-height: 1.8;
    }

    /* CTA Button styling for Probetraining links */
    .article-content a[href*="probetraining"] {
        display: inline-block;
        padding: 1rem 2rem;
        margin: 1rem 0;
        background: var(--color-primary, #DC143C);
        color: #fff !important;
        font-size: 1.1rem;
        font-weight: 700;
        text-decoration: none;
        border-radius: 10px;
        transition: all 0.25s ease;
        box-shadow: 0 4px 12px rgba(220, 20, 60, 0.3);
        text-align: center;
    }
    .article-content a[href*="probetraining"]:hover {
        background: var(--color-primary-dark, #a5102e);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(220, 20, 60, 0.4);
    }
</style>
