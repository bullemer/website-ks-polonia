---
import Layout from '../../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';

import badmintonTeam from '../../assets/images/badminton-team-turnier.jpg';
import badmintonSiegerehrung from '../../assets/images/badminton-siegerehrung-torun-2017.jpg';
import badmintonMedaille from '../../assets/images/badminton-medaille.jpg';
import badmintonSpiel from '../../assets/images/badminton-turnier-spiel.jpg';
import badmintonDoppel from '../../assets/images/badminton-doppel.jpg';

const galleryImages = [
    { src: badmintonTeam, alt: 'KS Polonia Badminton-Team beim internationalen Turnier', caption: 'Unser Team beim internationalen Turnier' },
    { src: badmintonSiegerehrung, alt: 'Siegerehrung bei den XVIII. Weltweiten Polonischen Sommerspielen in Toruń 2017', caption: 'Siegerehrung – Igrzyska Polonijne Toruń 2017' },
    { src: badmintonMedaille, alt: 'Silbermedaille bei internationalen Badminton-Meisterschaften', caption: 'Stolz mit Silbermedaille' },
    { src: badmintonSpiel, alt: 'Badminton-Doppel beim Turnierspiel in der Halle', caption: 'Spannende Doppel-Begegnung' },
    { src: badmintonDoppel, alt: 'Zwei Badminton-Spieler beim Turnier', caption: 'Sportliche Kameradschaft' },
];
---

<Layout 
    title="Badminton Hamburg – International erfolgreich | Igrzyska Polonijne"
    description="Badminton Hamburg beim KS Polonia – international erfolgreich bei den Polonischen Sommerspielen (Igrzyska Polonijne). Probetraining in Uhlenhorst für Anfänger und Fortgeschrittene. Polski klub badmintonowy w Hamburgu."
>
    <article class="prose badminton-page">
        <a href="/seiten" class="back-link">← Zurück zu Seiten</a>
        
        <h1>Badminton</h1>
        
        <div class="article-content">
            <p class="intro-text">
                Die <strong>Badminton-Abteilung des KS Polonia Hamburg e.V.</strong> gehört zu den erfolgreichsten Sparten unseres Vereins. 
                Seit Jahren vertreten unsere Spielerinnen und Spieler den Verein bei <strong>internationalen Turnieren</strong> und 
                <strong>polonischen Meisterschaften</strong> – und bringen regelmäßig Medaillen nach Hamburg zurück.
            </p>

            <h2>🏸 Internationale Erfolge</h2>
            <p>
                Unsere Badminton-Mannschaft nimmt regelmäßig an den <strong>Weltweiten Polonischen Sommerspielen (Igrzyska Polonijne)</strong> teil – 
                einem prestigeträchtigen internationalen Sportevent für polnische Gemeinschaften weltweit. Bei den <strong>XVIII. Igrzyska Polonijne 2017 in Toruń</strong> 
                konnte unsere Mannschaft herausragende Ergebnisse erzielen und mehrere Medaillen gewinnen.
            </p>
            <p>
                Darüber hinaus nehmen unsere Spielerinnen und Spieler an weiteren <strong>nationalen und internationalen Turnieren</strong> teil 
                und messen sich mit Badminton-Teams aus ganz Europa.
            </p>

            <h2>🎯 Training & Mitmachen</h2>
            <p>
                Du hast Interesse an Badminton und möchtest Teil unserer erfolgreichen Mannschaft werden? 
                Egal ob Anfänger oder erfahrener Spieler – bei uns bist du willkommen!
            </p>
            <p>
                <strong>Kontaktanfragen und Probetraining</strong> bitte per E-Mail anfragen:
            </p>
            <p class="contact-email">
                📧 <a href="mailto:badminton@ks-polonia.de">badminton@ks-polonia.de</a>
            </p>
        </div>

        <section class="gallery-section">
            <h2>📸 Galerie – Badminton bei KS Polonia</h2>
            <div class="gallery-grid">
                {galleryImages.map((img, i) => (
                    <figure class="gallery-item" data-index={i}>
                        <div class="gallery-img-wrapper">
                            <Image 
                                src={img.src} 
                                alt={img.alt} 
                                width={600}
                                quality={80}
                                class="gallery-img"
                                loading={i < 2 ? 'eager' : 'lazy'}
                            />
                            <div class="gallery-overlay">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="zoom-icon">
                                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                    <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                                </svg>
                            </div>
                        </div>
                        <figcaption>{img.caption}</figcaption>
                    </figure>
                ))}
            </div>
        </section>
    </article>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox">
        <button class="lightbox-close" id="lightboxClose" aria-label="Schließen">&times;</button>
        <button class="lightbox-prev" id="lightboxPrev" aria-label="Vorheriges Bild">&#10094;</button>
        <button class="lightbox-next" id="lightboxNext" aria-label="Nächstes Bild">&#10095;</button>
        <div class="lightbox-content">
            <img id="lightboxImg" src="" alt="" />
            <p class="lightbox-caption" id="lightboxCaption"></p>
        </div>
    </div>
</Layout>

<style>
    .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--color-text-muted);
    }
    .back-link:hover { color: var(--color-primary); }

    .badminton-page {
        max-width: 960px;
    }

    .intro-text {
        font-size: 1.05rem;
        line-height: 1.85;
        color: var(--color-text);
    }

    .contact-email {
        font-size: 1.1rem;
        font-weight: 600;
    }
    .contact-email a {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    /* ═══════════════════════════════════════
       GALLERY
       ═══════════════════════════════════════ */
    .gallery-section {
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
        margin-top: 1.5rem;
    }

    .gallery-item {
        margin: 0;
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--color-surface);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
    }
    .gallery-item:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .gallery-img-wrapper {
        position: relative;
        overflow: hidden;
        aspect-ratio: 4 / 3;
        background: #f0f0f0;
    }

    .gallery-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }
    .gallery-item:hover .gallery-img {
        transform: scale(1.05);
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        background: rgba(220, 20, 60, 0.0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.3s ease;
    }
    .gallery-item:hover .gallery-overlay {
        background: rgba(220, 20, 60, 0.15);
    }

    .zoom-icon {
        width: 36px;
        height: 36px;
        color: white;
        opacity: 0;
        transition: opacity 0.3s ease, transform 0.3s ease;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    }
    .gallery-item:hover .zoom-icon {
        opacity: 1;
        transform: scale(1.1);
    }

    figcaption {
        padding: 0.75rem 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--color-text-muted);
        text-align: center;
        line-height: 1.4;
    }

    /* ═══════════════════════════════════════
       LIGHTBOX
       ═══════════════════════════════════════ */
    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        animation: fadeIn 0.25s ease;
    }
    .lightbox.active {
        display: flex;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .lightbox-content {
        max-width: 90vw;
        max-height: 85vh;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .lightbox-content img {
        max-width: 90vw;
        max-height: 78vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    }

    .lightbox-caption {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 500;
        margin-top: 1rem;
        text-align: center;
        opacity: 0.85;
    }

    .lightbox-close {
        position: absolute;
        top: 1.25rem;
        right: 1.5rem;
        background: none;
        border: none;
        color: #fff;
        font-size: 2.5rem;
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.2s, transform 0.2s;
        z-index: 10;
        line-height: 1;
    }
    .lightbox-close:hover {
        opacity: 1;
        transform: scale(1.15);
    }

    .lightbox-prev,
    .lightbox-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
        font-size: 1.8rem;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, transform 0.2s;
        z-index: 10;
    }
    .lightbox-prev { left: 1.5rem; }
    .lightbox-next { right: 1.5rem; }
    .lightbox-prev:hover,
    .lightbox-next:hover {
        background: rgba(220, 20, 60, 0.5);
        transform: translateY(-50%) scale(1.1);
    }

    @media (max-width: 600px) {
        .gallery-grid {
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }
        figcaption {
            font-size: 0.75rem;
            padding: 0.5rem 0.6rem;
        }
        .lightbox-prev,
        .lightbox-next {
            width: 40px;
            height: 40px;
            font-size: 1.4rem;
        }
        .lightbox-prev { left: 0.75rem; }
        .lightbox-next { right: 0.75rem; }
    }
</style>

<script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightboxCaption');
    const lightboxClose = document.getElementById('lightboxClose');
    const lightboxPrev = document.getElementById('lightboxPrev');
    const lightboxNext = document.getElementById('lightboxNext');
    const galleryItems = document.querySelectorAll('.gallery-item');

    let currentIndex = 0;

    interface GalleryData {
        src: string;
        caption: string;
    }

    const images: GalleryData[] = Array.from(galleryItems).map(item => ({
        src: (item.querySelector('.gallery-img') as HTMLImageElement)?.src || '',
        caption: item.querySelector('figcaption')?.textContent || '',
    }));

    function openLightbox(index: number) {
        currentIndex = index;
        if (lightboxImg && lightboxCaption && lightbox) {
            lightboxImg.src = images[index].src;
            lightboxImg.alt = images[index].caption;
            lightboxCaption.textContent = images[index].caption;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    }

    function closeLightbox() {
        lightbox?.classList.remove('active');
        document.body.style.overflow = '';
    }

    function navigate(dir: number) {
        currentIndex = (currentIndex + dir + images.length) % images.length;
        openLightbox(currentIndex);
    }

    galleryItems.forEach((item, i) => {
        item.addEventListener('click', () => openLightbox(i));
    });

    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxPrev?.addEventListener('click', () => navigate(-1));
    lightboxNext?.addEventListener('click', () => navigate(1));

    lightbox?.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
        if (!lightbox?.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
    });
</script>
